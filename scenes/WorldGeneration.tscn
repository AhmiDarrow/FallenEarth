[node name="Instructions" type="RichTextLabel" parent="MainVBox"]
bbcode_enabled = true
text = "[center]Choose a seed to generate the hexagonal sphere world (RimWorld inspired: biomes from lat/temp/elev/rain).
Then select your starting grid/tile like choosing a colony site.
World gen first, then character creation, then overworld at chosen hex.[/center]"
horizontal_alignment = 1
autowrap_mode = 3

[node name="SeedHBox" type="HBoxContainer" parent="MainVBox"]
theme_override_constants/separation = 12
alignment = 1

[node name="SeedLabel" type="Label" parent="MainVBox/SeedHBox"]

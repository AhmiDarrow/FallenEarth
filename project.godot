; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Fallen Earth"
config/version="0.2.0"
run/main_scene="res://scenes/ui/Splash.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

SaveManager="*res://scripts/SaveManager.gd"
GameState="*res://scripts/GameState.gd"
RaceManager="*res://scripts/RaceManager.gd"
ClassManager="*res://scripts/ClassManager.gd"
AppearanceManager="*res://scripts/AppearanceManager.gd"
DisplayManager="*res://scripts/DisplayManager.gd"
GameManager="*res://scripts/GameManager.gd"
RiftRunner="*res://scripts/RiftRunner.gd"
GraphicsManager="*res://scripts/GraphicsManager.gd"
NPCManager="*res://scripts/NPCManager.gd"
MissionManager="*res://scripts/MissionManager.gd"
InventoryManager="*res://scripts/InventoryManager.gd"
ProgressionManager="*res://scripts/ProgressionManager.gd"
PartyNPCManager="*res://scripts/PartyNPCManager.gd"
CraftingManager="*res://scripts/CraftingManager.gd"
TownManager="*res://scripts/TownManager.gd"
SettlementManager="*res://scripts/SettlementManager.gd"
EquipmentManager="*res://scripts/EquipmentManager.gd"
BaseManager="*res://scripts/BaseManager.gd"
BaseShopManager="*res://scripts/BaseShopManager.gd"
DialogueManager="*res://scripts/DialogueManager.gd"
QuestTracker="*res://scripts/QuestTracker.gd"
LoadingTips="*res://scripts/LoadingTips.gd"
ModLoader="*res://scripts/ModLoader.gd"
ModAPI="*res://scripts/ModAPI.gd"
AmbientAudio="*res://scripts/AmbientAudio.gd"
MusicManager="*res://scripts/MusicManager.gd"
KeybindManager="*res://scripts/KeybindManager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/initial_position=1
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/size/initial_width=1280
window/size/initial_height=720

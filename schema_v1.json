{
  "version": "1.1",
  "description": "Schema definition for Fallen Earth core content JSONs, updated to improve syntax and enforce consistency.",
  "data_types": {
    "string": ["string"],
    "integer": ["integer"],
    "float": ["number"]
  },
  "components": {
    "Race": {
      "required_fields": [
        "name", "stats", "visual_tag", "origin_zone", "description"
      ],
      "structure": {
        "stats": {
          "type": "object",
          "properties": {
            "health": {"type": "integer", "min": 1},
            "energy": {"type": "integer", "min": 0},
            "hunger_cap": {"type": "integer", "min": 10"},
            "rad_resist": {"type": "integer", "min": 0}
          },
          "required": ["health", "energy", "hunger_cap"] 
        },
        "visual_tag": {"type": "string", "description": "The in-game asset ID."},
        "origin_zone": {"type": "string", "enum_values": ["upworld", "underworld", "independent", "neutral"]}
      }
    },
    "Faction": {
      "required_fields": [
        "name", 
        "origin_key", 
        "motto", 
        "starting_rep", 
        "npc_types"
      ],
      "structure": {
        "starting_rep": {"type": "integer"}, 
        "npc_types": {"type": "array", "elements": ["string"]}
      }
    },
    "Biome": {
      "required_fields": [
        "name", 
        "description", 
        "wildlife_modifiers", 
        "survival_risks"
      ],
      "structure": {
        "wildlife_modifiers": {
          "type": "object",
          "properties": {
            "preferred_race_tags": {"type": "array", "elements": ["string"]},
            "threat_multiplier": {"type": "float", "min": 0.1}
          },
          "required": ["preferred_race_tags"]
        },
        "survival_risks": {
          "type": "array",
          "elements": ["string"],
          "description": "e.g., ['Radiation', 'Extreme Cold', 'Resource Scarcity']"
        }
      }
    }
  }
}